          {
            "key": "wizard_server_cert",
            "desc": "Server Certificate Path",
            "defaultValue": ""
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "Absolute path to the server TLS private key file (PEM format).",
        "subitems": [
          {
            "key": "wizard_server_key",
            "desc": "Server Private Key Path",
            "defaultValue": ""
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "Absolute path to the CA certificate bundle (PEM format). Required for certificate-based client authentication; leave blank for password-only auth.",
        "subitems": [
          {
            "key": "wizard_ca_cert",
            "desc": "CA Certificate Path",
            "defaultValue": ""
          }
        ]
      }
