[
  {
    "step_title": "OpenConnect VPN — Network",
    "items": [
      {
        "type": "textfield",
        "desc": "VPN listening port (TCP and UDP). Port 443 offers maximum compatibility but conflicts with DSM HTTPS — the default 4433 avoids this.",
        "subitems": [
          {
            "key": "wizard_vpn_port",
            "desc": "VPN Port",
            "defaultValue": "4433",
            "validator": {
              "allowBlank": false,
              "regex": {
                "expr": "/^([1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$/",
                "errorText": "Enter a valid port number (1–65535)."
              }
            }
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "Absolute path to the server TLS certificate (PEM). You can use Synology's Let's Encrypt certificate from /usr/syno/etc/certificate/_archive/<id>/fullchain.pem.",
        "subitems": [
          {
            "key": "wizard_server_cert",
            "desc": "Server Certificate Path",
            "defaultValue": ""
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "Absolute path to the server TLS private key (PEM).",
        "subitems": [
          {
            "key": "wizard_server_key",
            "desc": "Server Private Key Path",
            "defaultValue": ""
          }
        ]
      }
    ]
  },
  {
    "step_title": "OpenConnect VPN — Authentication",
    "items": [
      {
        "type": "singleselect",
        "desc": "Choose how VPN users will authenticate.",
        "subitems": [
          {
            "key": "wizard_auth_method",
            "desc": "Authentication Method",
            "defaultValue": "local",
            "displayField": "name",
            "valueField": "value",
            "store": {
              "data": [
                { "name": "Local password file (ocpasswd)", "value": "local"  },
                { "name": "RADIUS server",                  "value": "radius" }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "step_title": "OpenConnect VPN — RADIUS Settings",
    "desc": "Fill in this page only if you selected RADIUS authentication.",
    "items": [
      {
        "type": "textfield",
        "desc": "Hostname or IP address of your RADIUS server.",
        "subitems": [
          {
            "key": "wizard_radius_host",
            "desc": "RADIUS Server Host",
            "defaultValue": ""
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "RADIUS authentication port (default: 1812).",
        "subitems": [
          {
            "key": "wizard_radius_auth_port",
            "desc": "Authentication Port",
            "defaultValue": "1812"
          }
        ]
      },
      {
        "type": "password",
        "desc": "Shared secret configured on your RADIUS server for this NAS client.",
        "subitems": [
          {
            "key": "wizard_radius_secret",
            "desc": "Shared Secret",
            "defaultValue": ""
          }
        ]
      },
      {
        "type": "textfield",
        "desc": "NAS identifier sent to the RADIUS server (leave blank to use the NAS hostname).",
        "subitems": [
          {
            "key": "wizard_radius_nas_id",
            "desc": "NAS Identifier",
            "defaultValue": ""
          }
        ]
      }
    ]
  }
]
